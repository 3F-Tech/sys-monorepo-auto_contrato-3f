        "type": "object",
        "properties": {
          "bu_id": {
            "type": "integer"
          },
          "bu_name": {
            "type": "string"
          },
          "amount": {
            "type": "number"
          },
          "is_inherited": {
            "type": "boolean"
          },
          "month": {
            "type": "integer"
          },
          "year": {
            "type": "integer"
          }
        }
      }
