            "type": "string",
            "description": "BigInt serializado"
          },
          "p1": {
            "type": "string",
            "nullable": true,
            "description": "Decimal"
          },
          "tcv": {
            "type": "string",
            "nullable": true,
            "description": "Decimal"
          },
          "nmrr": {
            "type": "string",
            "nullable": true,
            "description": "Decimal"
          },
          "implementation": {
            "type": "string",
            "nullable": true,
            "description": "Decimal"
          },
          "monthly": {
            "type": "string",
            "nullable": true,
            "description": "Decimal"
          },
          "month": {
            "type": "integer"
          },
          "year": {
            "type": "integer"
          },
          "created_by": {
            "type": "string",
            "description": "BigInt serializado"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
