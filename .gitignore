# --- SISTEMA E DESCARTE ---
.DS_Store
Thumbs.db
node_modules/
.npm
.pnpm-debug.log*

# --- CONFIGURAÇÕES DE AMBIENTE (SENSÍVEL) ---
# Jamais suba o .env da sua máquina para não quebrar o banco da VPS
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.pem
*.key

# --- CREDENCIAIS ESPECÍFICAS ---
# Protegendo arquivos de chaves de API e Google Sheets
google-credentials.json
GOOGLE_SHEETS_CREDENTIALS
# Caso o arquivo do messenger tenha outro nome JSON, coloque aqui:
sharp-messenger-*.json 

# --- TURBOREPO & CACHE ---
# O cache local (.turbo) não deve ir para a VPS para evitar conflitos de SO
.turbo/
# Logs de execução que poluem o Git
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# --- BUILD OUTPUTS ---
# Não subimos o código compilado, a VPS faz o build (pnpm build)
dist/
build/
out/
.next/
.nuxt/

# --- PRISMA & BANCO ---
# O schema.prisma DEVE subir, mas o diretório de geração local não
# (A VPS roda o 'prisma generate' lá)
# Se você tiver um arquivo de SQLite local para testes, ignore-o:
*.db
*.db-journal

# --- KUBB & SWAGGER ---
# Ignorar arquivos gerados automaticamente pelo Kubb
# (Eles serão gerados na VPS pelo 'pnpm codegen')
src/gen/
openapi.json
swagger.json

# --- IDES E EDITORES ---
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/launch.json
.idea/
*.sublime-project
*.sublime-workspace

# --- TESTES (PLAYWRIGHT / QA-UX) ---
test-results/
playwright-report/
blob-report/
playwright/.cache/
apps/web/tests/
skills/QA-Sentinal-*/
skills/QA-UX-*/

# --- REGRAS DE EXCEÇÃO (O QUE NÃO PODE SER IGNORADO) ---
# Garante que arquivos de configuração essenciais sempre subam
!package.json
!tsconfig.json
!turbo.json
!pnpm-workspace.yaml
!pnpm-lock.yaml
!kubb.config.ts
!prisma/schema.prisma