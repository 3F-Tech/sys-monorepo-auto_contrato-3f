# --- SISTEMA E DESCARTE ---
.DS_Store
Thumbs.db
node_modules/
.npm
.pnpm-debug.log*

# --- CONFIGURAÇÕES DE AMBIENTE (SENSÍVEL) ---
# Jamais suba o .env da sua máquina para não quebrar o banco da VPS
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.pem
*.key

# --- CREDENCIAIS ESPECÍFICAS ---
# Protegendo arquivos de chaves de API e Google Sheets
google-credentials.json
GOOGLE_SHEETS_CREDENTIALS
# Caso o arquivo do messenger tenha outro nome JSON, coloque aqui:
sharp-messenger-*.json 

# --- TURBOREPO & CACHE ---
# O cache local (.turbo) não deve ir para a VPS para evitar conflitos de SO
.turbo/
# Logs de execução que poluem o Git
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# --- BUILD OUTPUTS ---
# Não subimos o código compilado, a VPS faz o build (pnpm build)
dist/
build/
out/
.next/
.nuxt/

# --- PRISMA & BANCO ---
# O schema.prisma DEVE subir, mas o diretório de geração local não
# (A VPS roda o 'prisma generate' lá)
# Se você tiver um arquivo de SQLite local para testes, ignore-o:
*.db
*.db-journal

# --- KUBB & SWAGGER ---
# Ignorar arquivos gerados automaticamente pelo Kubb
# (Eles serão gerados na VPS pelo 'pnpm codegen')
src/gen/
openapi.json
swagger.json

# --- IDES E EDITORES ---
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/launch.json
.idea/
*.sublime-project
*.sublime-workspace

# --- TESTES (PLAYWRIGHT / QA-UX) ---
test-results/
playwright-report/
blob-report/
playwright/.cache/
apps/web/tests/
skills/QA-Sentinal-*/
skills/QA-UX-*/
# toPromptsOpencode/

# --- REGRAS DE EXCEÇÃO (O QUE NÃO PODE SER IGNORADO) ---
# Garante que arquivos de configuração essenciais sempre subam
!package.json
!tsconfig.json
!turbo.json
!pnpm-workspace.yaml
!pnpm-lock.yaml
!kubb.config.ts
!prisma/schema.prisma


# --- Arquivos do Sistema e Fantasmas (Windows/Git) ---
nul
[Nn][Uu][Ll]
Thumbs.db
.DS_Store

# --- Pastas de Logs e Temporários (Visto no seu git status) ---
tmp/
temp/
debug/
reports/
guide-test/
.opencode/
.claude/
apps/api/tmp/

# --- Scripts de Teste e Verificação Local ---
# (Arquivos que você criou para testar o banco ou hooks e não devem subir)
tmp_check_db.cjs
tmp_check_db_extended.cjs
tmp_check_sellers.cjs
tmp_test.js
apps/api/test_prisma.ts
apps/api/src/scripts/
tmp/check_contracts.ts
tmp/verify_sync.ts

# --- Build e Dependências (Padrão) ---
node_modules/
dist/
build/
.env
.env.*
!.env.example

# --- Cache de Skills e Ferramentas de IA (Limpando o legado) ---
skills/**/__pycache__/
*.pyc